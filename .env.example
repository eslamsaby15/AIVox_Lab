# ─────────────────────────────────────────────
# AIVox Lab — Environment Configuration
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────

# Application
APP_NAME="AIVox Lab"
APP_VERSION="1.0.0"
APP_DEBUG=false
LOG_LEVEL="INFO"           # DEBUG | INFO | WARNING | ERROR

# HuggingFace / Classical models
EN_MODEL="facebook/bart-large-cnn"
EN_AR_MODEL="Helsinki-NLP/opus-mt-en-ar"

# ── LLM Backend identifiers (do not change) ──
GENERATION_BACKEND_OPENAI="OpenAI"
GENERATION_BACKEND_GEMINI="Gemini"
GENERATION_BACKEND_COHERE="Cohere"

EMBEDDING_BACKEND_GEMINI="Gemini"
EMBEDDING_BACKEND="Cohere"

# ── API Keys (replace with your real keys) ────
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_KEY_HERE"
COHERE_API_KEY="YOUR_COHERE_KEY_HERE"
GEMINI_API_KEY="YOUR_GEMINI_KEY_HERE"

# ── Generation model IDs ──────────────────────
GENERATION_MODEL_ID_OPENAI="gpt-4o-mini"
GENERATION_MODEL_ID_GEMINI="gemini-2.0-flash"
GENERATION_MODEL_ID_COHERE_LIGHT="command-r-08-2024"

# ── Embedding model IDs ───────────────────────
EMBEDDING_MODEL_ID="text-embedding-3-small"
EMBEDDING_MODEL_ID_GEMINI="models/embedding-001"
EMBEDDING_MODEL_ID_COHERE_MULTILINGUAL="embed-multilingual-v3.0"

# ── API Endpoints ─────────────────────────────
OPENAI_API_URL="https://api.openai.com/v1"

# ── Generation defaults ───────────────────────
INPUT_DEFAULT_MAX_CHARACTERS=4096
GENERATION_DEFAULT_MAX_TOKENS=1024
GENERATION_DEFAULT_TEMPERATURE=0.3

# ── Storage ───────────────────────────────────
TEMP_DIR="src/assets/temp"
DATA_DIR="src/assets/Data"
